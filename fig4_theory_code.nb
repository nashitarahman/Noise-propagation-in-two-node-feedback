Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Positive", " ", "negative", " ", "feedback"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gx", "=", 
     FractionBox["Kyx", 
      RowBox[{"y", "+", "Kyx"}]]}], ";", 
    RowBox[{"gy", "=", 
     FractionBox["x", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]x", "*", "gx"}], "-", 
      RowBox[{"\[Beta]x", "*", "x"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ydot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]y", "*", "gy"}], "-", 
      RowBox[{"\[Beta]y", "*", "y"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xdot", "\[Equal]", "0"}], ",", 
         RowBox[{"ydot", "\[Equal]", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xav", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yav", "=", 
     RowBox[{"y", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fxyp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]x"}], "*", 
      FractionBox["Kyx", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"yav", "+", "Kyx"}], ")"}], "2"]]}]}], ";", 
    RowBox[{"fyxp", "=", 
     RowBox[{"\[Alpha]y", "*", 
      FractionBox["Kxy", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"xav", "+", "Kxy"}], ")"}], "2"]]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]yx", "=", 
     RowBox[{"\[Beta]y", "/", 
      RowBox[{"(", 
       RowBox[{"\[Beta]x", "+", "\[Beta]y"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Tau]xy", "=", 
     RowBox[{"\[Beta]x", "/", 
      RowBox[{"(", 
       RowBox[{"\[Beta]x", "+", "\[Beta]y"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"G", "=", 
     RowBox[{"fxyp", "*", 
      RowBox[{"fyxp", "/", 
       RowBox[{"(", 
        RowBox[{"\[Beta]x", "*", "\[Beta]y"}], ")"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xint", "=", 
     RowBox[{"1", "/", "xav"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xext", "=", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["fxyp", "2"], " ", "yav"}], 
       RowBox[{"\[Beta]x", 
        RowBox[{"(", 
         RowBox[{"\[Beta]x", "+", "\[Beta]y"}], ")"}], 
        SuperscriptBox["xav", "2"]}]], "*", 
      FractionBox["1", 
       RowBox[{"1", "-", "G"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xcy", " ", "=", 
     RowBox[{"\[Tau]yx", "*", " ", 
      FractionBox["G", 
       RowBox[{"1", "-", "G"}]], "*", "xint"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xtot", "=", 
     RowBox[{"xint", "+", "xext", "+", "xcy"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yint", "=", 
     RowBox[{"1", "/", "yav"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yext", "=", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["fyxp", "2"], " ", "xav"}], 
       RowBox[{"\[Beta]y", 
        RowBox[{"(", 
         RowBox[{"\[Beta]x", "+", "\[Beta]y"}], ")"}], 
        SuperscriptBox["yav", "2"]}]], "*", 
      FractionBox["1", 
       RowBox[{"1", "-", "G"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ycy", " ", "=", 
     RowBox[{"\[Tau]xy", "*", " ", 
      FractionBox["G", 
       RowBox[{"1", "-", "G"}]], "*", "yint"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ytot", "=", 
     RowBox[{"yint", "+", "yext", "+", "ycy"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
