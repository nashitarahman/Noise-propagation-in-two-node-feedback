        RowBox[{"(", 
         RowBox[{"\[Beta]x", "+", "\[Beta]y"}], ")"}], 
        SuperscriptBox["yav", "2"]}]], "*", 
      FractionBox["1", 
       RowBox[{"1", "-", "G"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ycy", " ", "=", 
     RowBox[{"\[Tau]xy", "*", " ", 
      FractionBox["G", 
       RowBox[{"1", "-", "G"}]], "*", "yint"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ytot", "=", 
