    RowBox[{"gy", "=", 
     FractionBox["x", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]x", "*", "gx"}], "-", 
