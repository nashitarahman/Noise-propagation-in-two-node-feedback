      RowBox[{"PlotStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Red", ",", "Thick"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Blue", ",", "Thick"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"BaseStyle", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"FontFamily", "\[Rule]", "\"\<Times\>\""}], ",", 
         RowBox[{"FontSize", "\[Rule]", "15"}], ",", 
         RowBox[{"FontWeight", "\[Rule]", "Bold"}]}], "}"}]}], ",", 
      RowBox[{"FrameLabel", "\[Rule]", 
