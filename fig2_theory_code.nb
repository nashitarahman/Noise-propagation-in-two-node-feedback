   RowBox[{
    RowBox[{
     RowBox[{"toEString", "[", "dat_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"dat", "\[Equal]", "0."}], 
       ",", "\"\<0.0000000000000000E+00\>\"", ",", 
       RowBox[{
        RowBox[{"MantissaExponent", "[", "dat", "]"}], "//", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"mantissa", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ",", 
             RowBox[{"exponent", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"mantissa", "<", "0"}], ",", "\"\<-\>\"", 
                 ",", "\"\<\>\""}], "]"}], ",", "\"\<0.\>\"", ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"PadRight", "[", 
                 RowBox[{
                  RowBox[{"First", "[", 
                   RowBox[{"RealDigits", "[", 
                    RowBox[{"mantissa", ",", "10", ",", "Automatic"}], "]"}], 
                   "]"}], ",", "16", ",", "0"}], "]"}]}], ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"exponent", "<", "0"}], ",", "\"\<E-\>\"", 
                 ",", "\"\<E+\>\""}], "]"}], ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"IntegerDigits", "[", 
                 RowBox[{"exponent", ",", "10", ",", "2"}], "]"}]}]}], "}"}], 
             "//", "Flatten"}], "//", "StringJoin"}]}], "]"}], "&"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
       "===", "===", "===", "===", "===", "===", "===", "=="}], "=", 
     RowBox[{"=", 
      RowBox[{
       RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "="}]}]}], 
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Parameters", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Alpha]x", "=", "10"}], ";", " ", 
    RowBox[{"\[Alpha]y", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]x", "=", "0.1"}], ";", " ", 
    RowBox[{"\[Beta]y", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Kyx", "=", 
     RowBox[{"50", "/", 
      RowBox[{"Sqrt", "[", "\[Delta]", "]"}]}]}], ";", " ", 
    RowBox[{"Kxy", "=", 
     RowBox[{"50", "*", 
      RowBox[{"Sqrt", "[", "\[Delta]", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Delta]i", "=", "0.1"}], ";", 
    RowBox[{"\[Delta]f", "=", "10"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"p4", "=", 
    RowBox[{"LogLinearPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"xcy", ",", "ycy"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Delta]", ",", "\[Delta]i", ",", "\[Delta]f"}], "}"}], ",", 
      RowBox[{"Frame", "\[Rule]", "True"}], ",", 
      RowBox[{"FrameStyle", "\[Rule]", 
       RowBox[{"Directive", "[", 
