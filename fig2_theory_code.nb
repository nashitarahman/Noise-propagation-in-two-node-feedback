    RowBox[{
     RowBox[{"toEString", "[", "dat_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"dat", "\[Equal]", "0."}], 
       ",", "\"\<0.0000000000000000E+00\>\"", ",", 
       RowBox[{
        RowBox[{"MantissaExponent", "[", "dat", "]"}], "//", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"mantissa", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ",", 
             RowBox[{"exponent", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"mantissa", "<", "0"}], ",", "\"\<-\>\"", 
                 ",", "\"\<\>\""}], "]"}], ",", "\"\<0.\>\"", ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"PadRight", "[", 
                 RowBox[{
                  RowBox[{"First", "[", 
                   RowBox[{"RealDigits", "[", 
                    RowBox[{"mantissa", ",", "10", ",", "Automatic"}], "]"}], 
                   "]"}], ",", "16", ",", "0"}], "]"}]}], ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"exponent", "<", "0"}], ",", "\"\<E-\>\"", 
                 ",", "\"\<E+\>\""}], "]"}], ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"IntegerDigits", "[", 
                 RowBox[{"exponent", ",", "10", ",", "2"}], "]"}]}]}], "}"}], 
             "//", "Flatten"}], "//", "StringJoin"}]}], "]"}], "&"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
