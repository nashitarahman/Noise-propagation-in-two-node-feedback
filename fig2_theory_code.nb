       RowBox[{"{", 
        RowBox[{"\"\<\!\(\*SubscriptBox[\(x\), \(cy\)]\)\>\"", 
         ",", "\"\<\!\(\*SubscriptBox[\(y\), \(cy\)]\)\>\""}], "}"}]}], ",", 
      RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"t4", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
