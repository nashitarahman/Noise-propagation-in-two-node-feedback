               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"mantissa", "<", "0"}], ",", "\"\<-\>\"", 
                 ",", "\"\<\>\""}], "]"}], ",", "\"\<0.\>\"", ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"PadRight", "[", 
