                  RowBox[{"First", "[", 
                   RowBox[{"RealDigits", "[", 
                    RowBox[{"mantissa", ",", "10", ",", "Automatic"}], "]"}], 
                   "]"}], ",", "16", ",", "0"}], "]"}]}], ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"exponent", "<", "0"}], ",", "\"\<E-\>\"", 
