   RowBox[{
    RowBox[{
     RowBox[{"toEString", "[", "dat_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"dat", "\[Equal]", "0."}], 
       ",", "\"\<0.0000000000000000E+00\>\"", ",", 
       RowBox[{
        RowBox[{"MantissaExponent", "[", "dat", "]"}], "//", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"mantissa", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ",", 
             RowBox[{"exponent", "=", 
              RowBox[{"#", "[", 
