Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Positive", " ", "negative", " ", "feedback"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gx", "=", 
     FractionBox["Kyx", 
      RowBox[{"y", "+", "Kyx"}]]}], ";", 
    RowBox[{"gy", "=", 
     FractionBox["x", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]x", "*", "gx"}], "-", 
