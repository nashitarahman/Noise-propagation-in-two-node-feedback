   RowBox[{"(*", "Autocorrelation", " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Sigma]xy2", "=", " ", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"fyxp", "*", "xav"}], " ", "+", " ", 
         RowBox[{"fxyp", "*", " ", "yav"}]}], ")"}], "*", "\[Beta]x", "*", 
       "\[Beta]y"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Beta]x", "+", "\[Beta]y"}], ")"}], "*", 
