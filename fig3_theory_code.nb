     RowBox[{
      RowBox[{"-", "\[Alpha]x"}], "*", 
      FractionBox["Kyx", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"yav", "+", "Kyx"}], ")"}], "2"]]}]}], ";", 
    RowBox[{"fyxp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]y"}], "*", 
      FractionBox["Kxy", 
