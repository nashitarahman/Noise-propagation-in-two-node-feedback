      RowBox[{"\[Alpha]y", "*", "gy"}], "-", 
      RowBox[{"\[Beta]y", "*", "y"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xdot", "\[Equal]", "0"}], ",", 
         RowBox[{"ydot", "\[Equal]", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xav", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yav", "=", 
     RowBox[{"y", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fxyp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]x"}], "*", 
      FractionBox["Kyx", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"yav", "+", "Kyx"}], ")"}], "2"]]}]}], ";", 
    RowBox[{"fyxp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]y"}], "*", 
      FractionBox["Kxy", 
