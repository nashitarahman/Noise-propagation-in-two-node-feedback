Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Negative", " ", "positive", " ", "feedback"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gx", "=", 
     FractionBox["y", 
      RowBox[{"y", "+", "Kyx"}]]}], ";", 
    RowBox[{"gy", "=", 
     FractionBox["Kxy", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]x", "*", "gx"}], "-", 
      RowBox[{"\[Beta]x", "*", "x"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ydot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]y", "*", "gy"}], "-", 
      RowBox[{"\[Beta]y", "*", "y"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xdot", "\[Equal]", "0"}], ",", 
         RowBox[{"ydot", "\[Equal]", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xav", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yav", "=", 
     RowBox[{"y", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fxyp", "=", 
     RowBox[{"\[Alpha]x", "*", 
      FractionBox["Kyx", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"yav", "+", "Kyx"}], ")"}], "2"]]}]}], ";", 
    RowBox[{"fyxp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]y"}], "*", 
      FractionBox["Kxy", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"xav", "+", "Kxy"}], ")"}], "2"]]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"G", "=", 
     RowBox[{"fxyp", "*", 
      RowBox[{"fyxp", "/", 
       RowBox[{"(", 
        RowBox[{"\[Beta]x", "*", "\[Beta]y"}], ")"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
