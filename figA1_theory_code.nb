Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Positive", " ", "negative", " ", "feedback"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gx", "=", 
     FractionBox["Kyx", 
      RowBox[{"y", "+", "Kyx"}]]}], ";", 
    RowBox[{"gy", "=", 
     FractionBox["x", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]x", "*", "gx"}], "-", 
      RowBox[{"\[Beta]x", "*", "x"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ydot", "=", 
     RowBox[{
      RowBox[{"\[Alpha]y", "*", "gy"}], "-", 
      RowBox[{"\[Beta]y", "*", "y"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xdot", "\[Equal]", "0"}], ",", 
         RowBox[{"ydot", "\[Equal]", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xav", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "1"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yav", "=", 
     RowBox[{"y", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", 
        RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fxyp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]x"}], "*", 
      FractionBox["Kyx", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"yav", "+", "Kyx"}], ")"}], "2"]]}]}], ";", 
    RowBox[{"fyxp", "=", 
     RowBox[{"\[Alpha]y", "*", 
      FractionBox["Kxy", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"xav", "+", "Kxy"}], ")"}], "2"]]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"G", "=", 
     RowBox[{"fxyp", "*", 
      RowBox[{"fyxp", "/", 
       RowBox[{"(", 
        RowBox[{"\[Beta]x", "*", "\[Beta]y"}], ")"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"===", "===", "===", "===", "===", "===", "===", "===", 
      RowBox[{"Data", " ", "Extraction", " ", "formatting"}], "===", "===", "===",
       "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"toEString", "[", "dat_", "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"dat", "\[Equal]", "0."}], 
       ",", "\"\<0.0000000000000000E+00\>\"", ",", 
       RowBox[{
        RowBox[{"MantissaExponent", "[", "dat", "]"}], "//", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"mantissa", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], ",", 
             RowBox[{"exponent", "=", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"mantissa", "<", "0"}], ",", "\"\<-\>\"", 
                 ",", "\"\<\>\""}], "]"}], ",", "\"\<0.\>\"", ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"PadRight", "[", 
                 RowBox[{
                  RowBox[{"First", "[", 
                   RowBox[{"RealDigits", "[", 
                    RowBox[{"mantissa", ",", "10", ",", "Automatic"}], "]"}], 
                   "]"}], ",", "16", ",", "0"}], "]"}]}], ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"exponent", "<", "0"}], ",", "\"\<E-\>\"", 
                 ",", "\"\<E+\>\""}], "]"}], ",", 
               RowBox[{"ToString", "/@", 
                RowBox[{"IntegerDigits", "[", 
                 RowBox[{"exponent", ",", "10", ",", "2"}], "]"}]}]}], "}"}], 
             "//", "Flatten"}], "//", "StringJoin"}]}], "]"}], "&"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
       "===", "===", "===", "===", "===", "===", "===", "=="}], "=", 
     RowBox[{"=", 
      RowBox[{
       RowBox[{"===", "===", "===", "===", "===", "===", "==="}], "="}]}]}], 
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Parameters", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Alpha]x", "=", "10"}], ";", " ", 
    RowBox[{"\[Alpha]y", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]x", "=", "0.1"}], ";", " ", 
    RowBox[{"\[Beta]y", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Kyx", "=", 
     RowBox[{"50", "/", 
      RowBox[{"Sqrt", "[", "\[Delta]", "]"}]}]}], ";", " ", 
    RowBox[{"Kxy", "=", 
     RowBox[{"50", "*", 
      RowBox[{"Sqrt", "[", "\[Delta]", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Delta]i", "=", "0.1"}], ";", 
    RowBox[{"\[Delta]f", "=", "10"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"LogLinearPlot", "[", 
    RowBox[{
     RowBox[{"{", "G", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Delta]", ",", "\[Delta]i", ",", "\[Delta]f"}], "}"}], ",", 
     RowBox[{"Frame", "\[Rule]", "True"}], ",", 
     RowBox[{"FrameStyle", "\[Rule]", 
      RowBox[{"Directive", "[", 
