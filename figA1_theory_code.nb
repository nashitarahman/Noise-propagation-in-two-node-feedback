               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"mantissa", "<", "0"}], ",", "\"\<-\>\"", 
                 ",", "\"\<\>\""}], "]"}], ",", "\"\<0.\>\"", ",", 
