     FractionBox["Kyx", 
      RowBox[{"y", "+", "Kyx"}]]}], ";", 
    RowBox[{"gy", "=", 
     FractionBox["Kxy", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
     RowBox[{
