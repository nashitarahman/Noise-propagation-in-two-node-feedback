 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Negative", " ", "positive", " ", "feedback"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gx", "=", 
     FractionBox["y", 
      RowBox[{"y", "+", "Kyx"}]]}], ";", 
    RowBox[{"gy", "=", 
     FractionBox["Kxy", 
      RowBox[{"x", "+", "Kxy"}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xdot", "=", 
