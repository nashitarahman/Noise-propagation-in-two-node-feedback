       RowBox[{"[", 
        RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fxyp", "=", 
     RowBox[{"\[Alpha]x", "*", 
      FractionBox["Kyx", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"yav", "+", "Kyx"}], ")"}], "2"]]}]}], ";", 
    RowBox[{"fyxp", "=", 
     RowBox[{
      RowBox[{"-", "\[Alpha]y"}], "*", 
